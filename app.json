{
  "expo": {
    "name": "HAKIKI Scanner",
    "slug": "hakiki_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hakikimobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "tz.hakiki.scanner",
      "infoPlist": {
        "NSCameraUsageDescription": "HAKIKI Scanner inahitaji kamera yako ili kukuruhusu kupiga picha za kukaguliwa.",
        "NSPhotoLibraryUsageDescription": "HAKIKI Scanner inahitaji ufikiaji wa picha zako ili kukuruhusu kuchagua picha za kukaguliwa.",
        "NSPhotoLibraryAddUsageDescription": "HAKIKI Scanner inaweza kuhifadhi matokeo ya picha kwenye matunzio yako."
      }
    },
    "android": {
      "package": "tz.hakiki.scanner",
      "adaptiveIcon": {
        "backgroundColor": "#0E1119",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0E1119",
          "dark": {
            "backgroundColor": "#0E1119"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8842ba21-5e58-425d-8829-b91a60542975"
      }
    },
    "updates": {
      "enabled": false
    }
  }
}
